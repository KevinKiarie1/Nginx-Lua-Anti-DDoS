    "@prisma/client": "^5.22.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cron-parser": "^5.5.0",
    "helmet": "^7.1.0",
    "playwright": "^1.48.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "telegraf": "^4.16.0",
    "user-agents": "^1.1.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
