# ============================================================
# CP-SOCIAL-BOT-FLEET-MODULAR — Production Configuration
# ============================================================
# Copy this file to .env.production and replace every placeholder.
# The production compose stack mounts TLS assets from
# ./ops/cockroach/certs and expects those files to exist.
# ============================================================

NODE_ENV="production"
ALLOW_UNAUTHENTICATED=false

# Application security
API_KEY="replace-with-a-strong-production-api-key"
ENCRYPTION_KEY="replace-with-a-64-char-hex-key"

# API server
PORT=3000

# CockroachDB bootstrap variables used by ops/cockroach/init/init-cluster.sh
COCKROACH_DATABASE="social_bot_fleet"
COCKROACH_APP_USER="social_bot_app"
COCKROACH_APP_PASSWORD="replace-with-a-strong-sql-password"

# Prisma / application connection string
# The CA certificate is mounted at /cockroach/certs/ca.crt by docker-compose.prod.yml
DATABASE_URL="postgresql://social_bot_app:replace-with-a-strong-sql-password@cockroach1:26257/social_bot_fleet?sslmode=verify-full&sslrootcert=/cockroach/certs/ca.crt"

# Worker configuration
WORKER_PLATFORMS="TELEGRAM,TIKTOK,INSTAGRAM,FACEBOOK"
WORKER_POLL_INTERVAL_MS=2000
WORKER_MAX_CONCURRENT_TASKS=5
WORKER_LEASE_DURATION_MS=300000
WORKER_LEASE_RENEW_INTERVAL_MS=30000
WORKER_TASK_TIMEOUT_MS=300000

# Cluster / consistency configuration
# Three API instances are defined in docker-compose.prod.yml; a quorum of two
# keeps health reporting accurate without blocking writes when redundancy drops.
CLUSTER_HEARTBEAT_INTERVAL_MS=5000
CLUSTER_NODE_TIMEOUT_MS=15000
CLUSTER_LEADER_LEASE_MS=15000
CLUSTER_MIN_NODES=2
STALE_TASK_TIMEOUT_MS=300000

# Rate limiting (per platform, per minute)
RATE_LIMIT_TELEGRAM=20
RATE_LIMIT_TIKTOK=5
RATE_LIMIT_INSTAGRAM=5
RATE_LIMIT_FACEBOOK=10

# Proxy pool
PROXY_LIST=""

# Telegram Bot
TELEGRAM_BOT_TOKEN=""

# Browser automation
BROWSER_HEADLESS=true
BROWSER_SLOW_MO=50