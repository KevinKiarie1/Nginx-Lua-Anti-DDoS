# ============================================================
# CP-SOCIAL-BOT-FLEET-MODULAR — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values.
# The app will refuse to start without DATABASE_URL, ENCRYPTION_KEY,
# and API_KEY unless ALLOW_UNAUTHENTICATED is explicitly set to true.
# ============================================================

NODE_ENV="development"
ALLOW_UNAUTHENTICATED=false

# Database (CockroachDB recommended for CP consistency)
DATABASE_URL="postgresql://root@localhost:26257/social_bot_fleet?sslmode=disable"

# Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY="change-me-generate-a-64-char-hex-key-with-crypto-randombytes32"

# API Server
PORT=3000
API_KEY="change-me-to-a-strong-api-key"

# Instance identity (unique per deployment / replica)
INSTANCE_ID="node-1"

# Worker configuration
WORKER_PLATFORMS="TELEGRAM,TIKTOK,INSTAGRAM,FACEBOOK"
WORKER_POLL_INTERVAL_MS=2000
WORKER_MAX_CONCURRENT_TASKS=5

# Cluster / CP consistency
CLUSTER_HEARTBEAT_INTERVAL_MS=5000
CLUSTER_NODE_TIMEOUT_MS=15000
CLUSTER_MIN_NODES=1
STALE_TASK_TIMEOUT_MS=300000

# Rate limiting (per platform, per minute)
RATE_LIMIT_TELEGRAM=20
RATE_LIMIT_TIKTOK=5
RATE_LIMIT_INSTAGRAM=5
RATE_LIMIT_FACEBOOK=10

# Proxy (comma-separated, format: protocol://user:pass@host:port)
PROXY_LIST=""

# Telegram Bot
TELEGRAM_BOT_TOKEN=""

# Browser automation
BROWSER_HEADLESS=true
BROWSER_SLOW_MO=50
